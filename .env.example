# Anthropic / Claude
ANTHROPIC_API_KEY=your_key_here

# OpenAI / ChatGPT
OPENAI_API_KEY=your_key_here

# Ollama (local, default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Whisper
WHISPER_MODEL=large-v3          # tiny / base / small / medium / large-v3
WHISPER_DEVICE=auto             # auto / cpu / cuda

# FFmpeg
FFMPEG_PATH=ffmpeg              # or full path if not in PATH

# Paths
DATA_INPUT_DIR=data/input
DATA_OUTPUT_DIR=data/output
DATA_TEMP_DIR=data/temp

# Social media clip defaults
CLIP_MAX_DURATION=60            # seconds
CLIP_ASPECT_RATIO=9:16          # 9:16 for TikTok/Reels, 16:9 for YouTube

# Adobe Premiere Pro
PREMIERE_HOST=localhost
PREMIERE_PORT=3000
